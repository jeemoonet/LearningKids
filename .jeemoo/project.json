{
  "$schema": "https://jeemoo.net/schemas/jeemookit-project-v1.json",
  "name": "LearningKids",
  "deploy": {
    "serverId": "OpenClaw1Y",
    "remotePath": "/home/ubuntu/LearningKids",
    "staticPath": "/var/www/fx",
    "service": "learningkids-api",
    "port": 3006,
    "apiPort": 3001,
    "domain": "43.128.98.192",
    "updateScript": "sudo systemctl restart learningkids-api && sudo rsync -a --delete dist-staging/ /var/www/fx/"
  },
  "permissions": {
    "agentCanDeploy": false,
    "agentCanModifyServer": false,
    "requireConfirmBeforeDeploy": true
  },
  "_comment": {
    "serverId": "对应 ~/.jeemoo/servers.json 中的 id",
    "keyFile": "不在此配置，由 servers.json + ~/.jeemoo/keys/ 解析",
    "permissions": "控制 Agent 是否可自动部署/改服务器配置"
  }
}
